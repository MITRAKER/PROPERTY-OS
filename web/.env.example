# Server-only key supplied by the class. Never prefix this with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8
ANTHROPIC_ENABLE_OPUS_FALLBACK=false
NEXT_PUBLIC_APP_NAME=Property OS

# Property Intelligence data source: "workspace" (default, reads the workspace's
# own records) or "nyc" (live NYC Open Data: GeoSearch + PLUTO + HPD + DOB + ACRIS).
# The NYC endpoints need no API key for light MVP usage. You can also override
# per request with /api/property/lookup?source=nyc.
PROPERTY_DATA_PROVIDER=workspace

# Authentication (Google OAuth). When these are unset, the app runs in local dev
# mode with an auto-provisioned "Local Developer" user (no login required).
# In production, set all three to require sign-in and isolate data per workspace.
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# with authorized redirect URI: https://<your-domain>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# A long random string used to sign session cookies. Generate with:
#   node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
SESSION_SECRET=

# Outreach delivery. Drafts only send after a person approves them AND the
# compliance gate (do-not-contact + channel permission) passes at send time.
# Email via Resend:
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
# SMS via Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Note: voice calls are intentionally dialed by a person, never auto-placed.
#
# Compliance settings for the send-time gate:
#   OUTREACH_MAILING_ADDRESS  Physical postal address required in every email by
#                             CAN-SPAM. Appears in the footer of outbound email.
#   OUTREACH_SENDER_NAME      Who the outreach is from (defaults to OUTREACH_FROM_EMAIL).
#   OUTREACH_TIMEZONE         Business timezone for the 8am–9pm calling/texting
#                             quiet-hours check (default: America/New_York).
OUTREACH_MAILING_ADDRESS=
OUTREACH_SENDER_NAME=
OUTREACH_TIMEZONE=

# Contact data ("skip tracing"). No free source of homeowner phone numbers exists.
# Leave unset to work manually or via the bulk CSV export/import (cheapest path).
# To go live with one-click lookups, set a vendor and its key:
#   BatchData:  CONTACT_DATA_PROVIDER=batchdata  + SKIPTRACE_API_KEY
#   Any other:  CONTACT_DATA_PROVIDER=<name>     + SKIPTRACE_API_URL + SKIPTRACE_API_KEY
CONTACT_DATA_PROVIDER=
# Endpoint for the generic skip-trace adapter (not needed for the batchdata preset).
SKIPTRACE_API_URL=
SKIPTRACE_API_KEY=
# Optional overrides for the generic adapter:
#   SKIPTRACE_AUTH_HEADER  header carrying the key (default: Authorization)
#   SKIPTRACE_AUTH_SCHEME  scheme prefix; set empty for x-api-key style (default: Bearer)
#   SKIPTRACE_BODY_STYLE   request shape: "flat" (default) or "batchdata"
SKIPTRACE_AUTH_HEADER=
SKIPTRACE_AUTH_SCHEME=
SKIPTRACE_BODY_STYLE=
